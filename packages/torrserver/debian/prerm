#!/bin/bash
set -e

# Stop and disable the service before removal
if [ -d /run/systemd/system ]; then
    if systemctl is-active --quiet torrserver.service 2>/dev/null; then
        systemctl stop torrserver.service >/dev/null 2>&1 || true
    fi
    if systemctl is-enabled --quiet torrserver.service 2>/dev/null; then
        systemctl disable torrserver.service >/dev/null 2>&1 || true
    fi
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

exit 0
