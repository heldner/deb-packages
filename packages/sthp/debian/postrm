#!/bin/bash
set -e

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    if getent passwd sthp >/dev/null 2>&1; then
        userdel sthp >/dev/null 2>&1 || true
    fi

    if getent group sthp >/dev/null 2>&1; then
        if [ -z "$(getent group sthp | cut -d: -f4)" ]; then
            groupdel sthp >/dev/null 2>&1 || true
        fi
    fi
fi

exit 0
